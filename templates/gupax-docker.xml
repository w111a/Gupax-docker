<?xml version="1.0"?>
<Container version="2">
  <Name>gupax</Name>
  <Repository>ghcr.io/w111a/gupax-docker:latest</Repository>
  <Registry>https://github.com/w111a/Gupax-docker/pkgs/container/gupax-docker</Registry>
  <Network>bridge</Network>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/w111a/Gupax-docker/issues</Support>
  <Project>https://github.com/w111a/Gupax-docker</Project>
  <Overview>Gupax-docker runs the Gupax GUI for P2Pool + XMRig Monero mining via noVNC web interface.&#13;&#10;&#13;&#10;Access the GUI at http://your-unraid-ip:6080 - just open in your browser, no X11 needed.&#13;&#10;&#13;&#10;IMPORTANT: You MUST set your WALLET_ADDRESS before starting. Mining cryptocurrency consumes significant electricity.</Overview>
  <Category>Crypto:</Category>
  <WebUI>http://[IP]:[PORT:6080]</WebUI>
  <Icon>https://raw.githubusercontent.com/gupax-io/gupax/main/assets/images/banner.png</Icon>
  <ExtraParams></ExtraParams>
  <PostArgs></PostArgs>

  <!-- ============================================================ -->
  <!-- Environment Variables                                        -->
  <!-- ============================================================ -->
  <Environment>
    <Variable>
      <Name>WALLET_ADDRESS</Name>
      <Value></Value>
      <Mode></Mode>
      <Description>Your Monero wallet address for mining payouts. REQUIRED.</Description>
      <Display>always</Display>
      <Required>true</Required>
      <Mask>never</Mask>
    </Variable>
  </Environment>

  <!-- ============================================================ -->
  <!-- Ports                                                        -->
  <!-- ============================================================ -->
  <Ports>
    <Port>
      <HostPort>6080</HostPort>
      <ContainerPort>6080</ContainerPort>
      <Protocol>tcp</Protocol>
      <Description>noVNC web interface - connect your browser here</Description>
      <Display>always</Display>
    </Port>
    <Port>
      <HostPort>5900</HostPort>
      <ContainerPort>5900</ContainerPort>
      <Protocol>tcp</Protocol>
      <Description>VNC server (optional - for direct VNC clients)</Description>
      <Display>advanced</Display>
    </Port>
    <Port>
      <HostPort>3333</HostPort>
      <ContainerPort>3333</ContainerPort>
      <Protocol>tcp</Protocol>
      <Description>P2Pool Stratum - Connect your miners here</Description>
      <Display>advanced</Display>
    </Port>
    <Port>
      <HostPort>37889</HostPort>
      <ContainerPort>37889</ContainerPort>
      <Protocol>tcp</Protocol>
      <Description>P2Pool Monero Node ZMQ</Description>
      <Display>advanced</Display>
    </Port>
    <Port>
      <HostPort>18080</HostPort>
      <ContainerPort>18080</ContainerPort>
      <Protocol>tcp</Protocol>
      <Description>Monero P2P Network</Description>
      <Display>advanced</Display>
    </Port>
    <Port>
      <HostPort>18081</HostPort>
      <ContainerPort>18081</ContainerPort>
      <Protocol>tcp</Protocol>
      <Description>Monero RPC</Description>
      <Display>advanced</Display>
    </Port>
  </Ports>

  <!-- ============================================================ -->
  <!-- Volumes                                                      -->
  <!-- ============================================================ -->
  <Volumes>
    <Volume>
      <HostDir>/mnt/user/appdata/gupax/config</HostDir>
      <ContainerDir>/home/miner/.local/state/gupax</ContainerDir>
      <Mode>rw</Mode>
      <Description>Gupax configuration and state (persists settings)</Description>
      <Display>always</Display>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/gupax/monero</HostDir>
      <ContainerDir>/home/miner/.bitmonero</ContainerDir>
      <Mode>rw</Mode>
      <Description>Monero blockchain data. IMPORTANT: In Gupax UI, go to Node tab and set database path to /home/miner/.bitmonero</Description>
      <Display>always</Display>
    </Volume>
  </Volumes>

  <!-- ============================================================ -->
  <!-- Restart Policy                                               -->
  <!-- ============================================================ -->
  <RestartPolicy>unless-stopped</RestartPolicy>

</Container>
