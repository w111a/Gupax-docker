<?xml version="1.0"?>
<Container version="2">
  <Name>gupax</Name>
  <Repository>ghcr.io/w111a/gupax-docker:feat-tor-node</Repository>
  <Registry>ghcr.io/w111a/gupax-docker</Registry>
  <Network>bridge</Network>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/w111a/Gupax-docker/issues</Support>
  <Project>https://github.com/w111a/Gupax-docker</Project>
  <Overview>Gupax-docker runs the Gupax GUI for P2Pool + XMRig Monero mining via noVNC web interface.

Access the GUI at http://your-unraid-ip:6080 - just open in your browser, no X11 needed.

This is a development build with Tor support included. Set TOR_ENABLED=true to run a Tor SOCKS5 proxy and onion hidden service for anonymous Monero P2P. Use libre7/gupax-docker:latest for the stable version.

Set your Monero wallet address inside the Gupax GUI itself (P2Pool tab). Mining cryptocurrency consumes significant electricity and may not be profitable.</Overview>
  <Category>Crypto:</Category>
  <WebUI>http://[IP]:[PORT:6080]</WebUI>
  <Icon>https://raw.githubusercontent.com/gupax-io/gupax/main/assets/images/icons/icon.png</Icon>
  <ExtraParams>--security-opt no-new-privileges:true</ExtraParams>
  <PostArgs></PostArgs>

  <!-- ============================================================ -->
  <!-- Environment Variables                                        -->
  <!-- ============================================================ -->
  <Environment>
    <Variable>
      <Name>VNC_PASSWORD</Name>
      <Value></Value>
      <Mode></Mode>
      <Description>VNC password — set this to require authentication for the noVNC web interface. Leave empty to disable auth (not recommended on exposed networks).</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>true</Mask>
    </Variable>
    <Variable>
      <Name>TOR_ENABLED</Name>
      <Value>false</Value>
      <Mode></Mode>
      <Description>Set to true to enable a Tor SOCKS5 proxy (127.0.0.1:9050) and onion hidden service for anonymous Monero P2P connections. Hidden service exposes port 18080 P2P only — not RPC.</Description>
      <Display>always</Display>
      <DisplayName>Tor (Enable Tor Proxy + Hidden Service)</DisplayName>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>SCREEN_RESOLUTION</Name>
      <Value>1920x1080x24</Value>
      <Mode></Mode>
      <Description>Display resolution for Gupax GUI inside the container (default: 1920x1080x24)</Description>
      <Display>advanced</Display>
      <DisplayName>Screen Resolution</DisplayName>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>
  </Environment>

  <!-- ============================================================ -->
  <!-- Ports                                                        -->
  <!-- ============================================================ -->
  <Ports>
    <Port>
      <HostPort>6080</HostPort>
      <ContainerPort>6080</ContainerPort>
      <Protocol>tcp</Protocol>
      <Description>noVNC web interface - connect your browser here</Description>
      <Display>always</Display>
    </Port>
    <Port>
      <HostPort>5900</HostPort>
      <ContainerPort>5900</ContainerPort>
      <Protocol>tcp</Protocol>
      <Description>VNC server (optional - for direct VNC clients)</Description>
      <Display>advanced</Display>
    </Port>
    <Port>
      <HostPort>3333</HostPort>
      <ContainerPort>3333</ContainerPort>
      <Protocol>tcp</Protocol>
      <Description>P2Pool Stratum - Connect external miners here</Description>
      <Display>advanced</Display>
    </Port>
    <Port>
      <HostPort>37889</HostPort>
      <ContainerPort>37889</ContainerPort>
      <Protocol>tcp</Protocol>
      <Description>P2Pool Monero Node ZMQ</Description>
      <Display>advanced</Display>
    </Port>
    <Port>
      <HostPort>18080</HostPort>
      <ContainerPort>18080</ContainerPort>
      <Protocol>tcp</Protocol>
      <Description>Monero P2P Network</Description>
      <Display>advanced</Display>
    </Port>
    <Port>
      <HostPort>18081</HostPort>
      <ContainerPort>18081</ContainerPort>
      <Protocol>tcp</Protocol>
      <Description>Monero RPC</Description>
      <Display>advanced</Display>
    </Port>
    <Port>
      <HostPort>18082</HostPort>
      <ContainerPort>18082</ContainerPort>
      <Protocol>tcp</Protocol>
      <Description>Monero RPC ZMQ</Description>
      <Display>hidden</Display>
    </Port>
  </Ports>

  <!-- ============================================================ -->
  <!-- Volumes                                                      -->
  <!-- ============================================================ -->
  <Volumes>
    <Volume>
      <HostDir>/mnt/user/appdata/gupax/config</HostDir>
      <ContainerDir>/home/miner/.local/share/gupax</ContainerDir>
      <Mode>rw</Mode>
      <Description>Gupax configuration and state (wallet, settings persist here)</Description>
      <Display>always</Display>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/gupax/monero</HostDir>
      <ContainerDir>/home/miner/.bitmonero</ContainerDir>
      <Mode>rw</Mode>
      <Description>Monero blockchain data. In Gupax UI, go to Node tab and set database path to /home/miner/.bitmonero</Description>
      <Display>always</Display>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/gupax/tor</HostDir>
      <ContainerDir>/home/miner/.tor</ContainerDir>
      <Mode>rw</Mode>
      <Description>Tor hidden service keys (optional). Mount this to keep the same .onion address across container restarts. Only used when TOR_ENABLED=true.</Description>
      <Display>advanced</Display>
    </Volume>
  </Volumes>

  <!-- ============================================================ -->
  <!-- Restart Policy                                               -->
  <!-- ============================================================ -->
  <RestartPolicy>unless-stopped</RestartPolicy>

  <!-- ============================================================ -->
  <!-- Logging                                                      -->
  <!-- ============================================================ -->
  <LogFile></LogFile>
  <LogDisplayFile>/dev/null</LogDisplayFile>
  <LogReader>true</LogReader>
  <LogMaxSize>10M</LogMaxSize>
  <LogMaxFile>3</LogMaxFile>

</Container>