# =============================================================================
# Gupax-docker Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# REQUIRED: Your Monero wallet address
WALLET_ADDRESS=

# Optional: Run P2Pool in mini mode (default: true)
P2POOL_MINI=true

# Optional: Number of XMRig threads (0 = auto, default: 0)
XMRIG_THREADS=0

# Optional: Monero node configuration (default: auto)
#   auto    - Use p2pool's built-in node detection
#   local   - Connect to local Monero node
#   remote  - Connect to external node (set MONERO_RPC_HOST below)
MONERO_NODE=auto

# Optional: Monero RPC host (only used when MONERO_NODE=remote)
# MONERO_RPC_HOST=127.0.0.1

# Optional: Monero RPC port (only used when MONERO_NODE=remote)
# MONERO_RPC_PORT=18081

# Optional: P2Pool stratum port (default: 3333)
# P2POOL_STRATUM_PORT=3333

# Optional: P2Pool Monero node ZMQ port (default: 37889)
# P2POOL_MONERO_PORT=37889

# Optional: Binary versions and checksums (defaults are set in docker-compose.yml)
# These are used for build-time verification of downloaded binaries
# Run scripts/get-checksums.sh to get the latest checksums
# P2POOL_VERSION=v4.14
# P2POOL_SHA256=e64f6f774dc35352b8ae4397ccdb92ce0cc935cdfb100eac58d44e49f8796a01
# XMRIG_VERSION=6.26.0
# XMRIG_SHA256=fc6f8ae5f64e4f17481f7e3be29a1c56949f216a998414188003eae1db20c9e5
