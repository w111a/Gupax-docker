# =============================================================================
# Gupax-docker Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ── TOR (Optional Hidden Service) ─────────────────────────────────────────────
# Set to true to run a Tor daemon inside the container:
#   - SOCKS5 proxy on 127.0.0.1:9050 for outbound Monero P2P via Tor
#   - .onion hidden service exposing port 18080 for anonymous inbound P2P
# When enabled, check container logs for the .onion address and recommended
# monerod arguments (Gupax → Node tab → Arguments).
# 
# Persistent .onion: uncomment the gupax-tor volume in docker-compose.yml
# ------------------------------------------------------------------------------
TOR_ENABLED=false

# ── VNC AUTHENTICATION (Optional) ─────────────────────────────────────────────
# Set a password to require authentication for the noVNC web interface.
# Leave empty for no password (default).
# ------------------------------------------------------------------------------
# VNC_PASSWORD=your_secure_password_here

# ── DISPLAY RESOLUTION ────────────────────────────────────────────────────────
# Screen resolution for the Gupax GUI inside the container.
# Format: WIDTHxHEIGHTxDEPTH  (default: 1920x1080x24)
# ------------------------------------------------------------------------------
# SCREEN_RESOLUTION=1920x1080x24

# ── MONERO BLOCKCHAIN DATA PATH ─────────────────────────────────────────────
# Mount a host directory or named volume containing your existing blockchain.
# If empty, defaults to named volume 'gupax-monero'.
#
# Examples:
#   Host directory:  /mnt/user/blockchain:/home/miner/.bitmonero
#   Named volume:      gupax-my-blockchain:/home/miner/.bitmonero
# ------------------------------------------------------------------------------
MONERO_DATA_PATH=

# =============================================================================
# QUICK START
# =============================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Adjust values above as needed
# 3. Start:            docker compose up -d
# 4. Open browser:     http://localhost:6080
# 5. Click "Connect" to access the Gupax GUI
# =============================================================================
#
# NOTE: To use an existing blockchain, set MONERO_DATA_PATH above and in the
# Gupax UI (Node tab) set the database path to:
#   /home/miner/.bitmonero
# =============================================================================
